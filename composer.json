{
  "name": "fetch-hive/sdk",
  "description": "Official PHP SDK for the Fetch Hive API",
  "version": "0.2.0",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Fetch Hive",
      "email": "tom@fetchhive.com",
      "homepage": "https://fetchhive.com"
    }
  ],
  "keywords": ["fetchhive", "ai", "agents", "workflows", "sdk"],
  "homepage": "https://fetchhive.com",
  "require": {
    "php": ">=8.1",
    "guzzlehttp/guzzle": "^7.5"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "FetchHive\\Sdk\\": "lib/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "FetchHive\\Sdk\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "stable"
}
